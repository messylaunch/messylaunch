{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run seed)",
      "Bash(npm run dev:*)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx prisma validate)",
      "Bash(npx prisma format:*)",
      "Bash(npx prisma db push)",
      "Bash(node scripts/smoke.mjs)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Bash(npx prisma db push --force-reset:*)",
      "Bash(npx prisma migrate reset:*)",
      "Bash(rm -rf prisma:*)"
    ]
  }
}
